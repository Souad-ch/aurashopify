# قاعدة البيانات (PostgreSQL) — على Vercel يُضاف تلقائياً عند ربط Vercel Postgres
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# مفتاح سري لتوقيع جلسات الدخول (أي نص عشوائي طويل)
AUTH_SECRET="change-this-to-a-long-random-string"

# Stripe (اختياري) — لتفعيل الدفع الحقيقي للاشتراكات. بدونها يعمل وضع تجريبي.
# خذها من stripe.com → Developers → API keys (استخدم مفاتيح test أولاً)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
