generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  passwordHash  String
  role          String         @default("merchant") // merchant | admin | designer
  createdAt     DateTime       @default(now())

  store         Store?
  subscription  Subscription?
  orders        Order[]
  themes        Theme[]
}

model Theme {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String
  // style tokens (mirror the built-in Template type)
  hero            String   @default("gradient") // gradient | image | split | centered
  font            String   @default("sans")     // sans | serif
  productColumns  Int      @default(4)
  cardStyle       String   @default("shadow")   // shadow | border | flat
  rounded         String   @default("rounded-2xl")
  uppercaseTitles Boolean  @default(false)
  accentColor     String   @default("#2563eb")
  price           Float    @default(0)          // 0 = free
  status          String   @default("draft")    // draft | published
  sales           Int      @default(0)
  createdAt       DateTime @default(now())

  designerId      String
  designer        User     @relation(fields: [designerId], references: [id], onDelete: Cascade)

  purchases       ThemePurchase[]
}

model ThemePurchase {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  price     Float    @default(0)

  themeId   String
  theme     Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)

  storeId   String

  @@unique([themeId, storeId])
}

model Store {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  currency    String     @default("USD")
  logoUrl     String?
  themeColor  String     @default("#2563eb")
  template    String     @default("modern")
  tagline     String?
  onboarded   Boolean    @default(false)
  email       String?
  phone       String?
  address     String?
  createdAt   DateTime   @default(now())

  ownerId     String     @unique
  owner       User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  products    Product[]
  orders      Order[]
  customers   Customer[]
  discounts   Discount[]
}

model Product {
  id          String      @id @default(cuid())
  title       String
  description String?
  price       Float
  compareAt   Float?
  sku         String?
  stock       Int         @default(0)
  imageUrl    String?
  status      String      @default("active") // active | draft | archived
  category    String?
  createdAt   DateTime    @default(now())

  storeId     String
  store       Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)

  variants    Variant[]
  orderItems  OrderItem[]
}

model Variant {
  id        String  @id @default(cuid())
  name      String  // e.g. "أحمر / M"
  price     Float?  // optional override; null => use product price
  stock     Int     @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Discount {
  id        String   @id @default(cuid())
  code      String
  type      String   @default("percent") // percent | fixed
  value     Float
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, code])
}

model Customer {
  id           String   @id @default(cuid())
  name         String
  email        String
  phone        String?
  passwordHash String?  // set when the customer creates a storefront account
  createdAt    DateTime @default(now())

  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  orders    Order[]

  @@unique([storeId, email])
}

model Order {
  id          String      @id @default(cuid())
  number      Int         @default(1000)
  total       Float
  status      String      @default("pending") // pending | paid | fulfilled | cancelled | refunded
  createdAt   DateTime    @default(now())

  storeId     String
  store       Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)

  customerId  String?
  customer    Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)

  userId      String?
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  items       OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int     @default(1)
  price     Float
  title     String

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model Plan {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  priceMonthly  Float
  priceYearly   Float
  description   String
  features      String         // JSON array string
  highlighted   Boolean        @default(false)
  order         Int            @default(0)

  subscriptions Subscription[]
}

model Subscription {
  id         String   @id @default(cuid())
  status     String   @default("active") // active | trialing | cancelled | past_due
  interval   String   @default("monthly") // monthly | yearly
  startedAt  DateTime @default(now())
  renewsAt   DateTime

  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  planId     String
  plan       Plan     @relation(fields: [planId], references: [id])
}
